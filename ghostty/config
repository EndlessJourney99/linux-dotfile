font-family=FiraCode Nerd Font
font-size=9
background-opacity=0.8
alpha-blending=linear
adjust-cell-height=5%
gtk-custom-css = tab-style.css
gtk-wide-tabs = false
gtk-tabs-location = bottom
gtk-titlebar = false
confirm-close-surface=false
shell-integration-features=no-title
resize-overlay=never
working-directory=home
window-inherit-working-directory=false
shell-integration=zsh

# Key bindings
keybind = ctrl+super+t=new_tab
keybind = ctrl+shift+q=close_tab
keybind = ctrl+super+l=next_tab
keybind = ctrl+super+h=previous_tab
keybind = ctrl+shift+r=reload_config
keybind = ctrl+alt+r=reset_font_size
keybind = ctrl+shift+e=text:yazi\n

# Unbind
keybind = ctrl+shift+t=unbind
keybind = ctrl+enter=unbind
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind
keybind = ctrl+minus=unbind
keybind = ctrl+equal=unbind
keybind = ctrl+,=unbind
